# Copy to `.env.local` and fill from Firebase console:
#   Project settings → Your apps → Web app → SDK setup & config.
# These are PUBLIC client values (safe to expose). NEXT_PUBLIC_* are inlined at
# BUILD time, so they must also be present when the web image is built for deploy.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=checkin-georgia-dev
NEXT_PUBLIC_FIREBASE_APP_ID=

# Already used by the app for API calls (defaults to the dev Cloud Run URL):
# NEXT_PUBLIC_API_URL=https://checkin-georgia-api-171625154738.europe-west1.run.app
